# Šis failas naudojamas Electron desktop programos build'ui su centralizuotu auth serveriu.
# Nukopijuokite į .env.desktop ir įrašykite tikrą render.com URL.
#
# Vite automatiškai nuskaito .env.desktop kai paleista su --mode desktop.
#
# Naudojimas:
#   cp .env.desktop.example .env.desktop
#   # Pakeiskite URL žemiau tikru render.com adresu
#   npm run installer:win:online

# Render.com paslaugos URL (be / gale)
VITE_AUTH_API_BASE_URL=https://led-ekranu-skaiciuokle.onrender.com

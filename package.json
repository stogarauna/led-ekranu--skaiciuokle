{
    "name": "led-ekranu-skaiciuokle",
    "private": true,
    "version": "1.0.0",
    "description": "LED ekranu skaiciuokle ir perziuros programa",
    "author": "stoga",
    "type": "module",
    "main": "electron/main.js",
    "scripts": {
        "dev": "concurrently -k \"npm:renderer\" \"npm:electron\"",
        "dev:web": "concurrently -k \"npm:auth-server\" \"npm:renderer\"",
        "renderer": "vite --host 127.0.0.1 --port 5173 --strictPort",
        "electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
        "auth-server": "node server/auth-server.js",
        "build": "tsc -b && vite build",
        "generate:icons": "node build/generate-icons.cjs",
        "start": "electron .",
        "lint": "eslint .",
        "preview": "vite preview",
        "dist:win": "npm.cmd run build && npm.cmd run generate:icons && electron-builder --win dir",
        "installer:win": "npm.cmd run dist:win && node electron/build-installer.cjs"
    },
    "dependencies": {
        "html-to-image": "^1.11.13",
        "react": "^19.2.5",
        "react-dom": "^19.2.5"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/vite": "^4.2.4",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^41.3.0",
        "electron-builder": "^26.8.1",
        "electron-winstaller": "^5.4.0",
        "eslint": "^10.2.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "png-to-ico": "^3.0.1",
        "pngjs": "^7.0.0",
        "typescript": "^6.0.3",
        "wait-on": "^9.0.5"
    },
    "build": {
        "appId": "lt.skaiciuokesvp.ledpreview",
        "productName": "LED Ekranu Skaiciuokle",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "electron/**/*",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "data",
                "to": "data"
            }
        ],
        "win": {
            "icon": "build/icon.ico",
            "executableName": "LED Ekranu Skaiciuokle",
            "target": [
                "dir"
            ]
        }
    }
}
